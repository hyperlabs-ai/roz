# roz — environment configuration
# Copy to `.env` and fill in. See docs/GITHUB-SETUP.md and the Self-hosting section
# of the README for how to obtain each value.
#
# In production (ROZ_ENV=production) the variables marked [required in prod] must be
# set or the server fails fast on boot.

# ── Runtime ───────────────────────────────────────────────────────────────────
ROZ_ENV=development            # development | production
ROZ_LOG_LEVEL=info
PORT=3000                      # local dev only

# ── Supabase (Postgres + pgvector; schema `roz` must be exposed in API settings) ─
SUPABASE_URL=                  # [required in prod] https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=     # [required in prod] server-side only, never shipped to the client
SUPABASE_ANON_KEY=             # [required in prod] used only to validate the dashboard user's JWT

# ── Dashboard ───────────────────────────────────────────────────────────────────
# Comma-separated email domains allowed to sign in to the dashboard. Empty = nobody
# passes the domain filter in prod (set your own, e.g. acme.com,acme.io).
DASHBOARD_ALLOWED_DOMAINS=
# Public URL of the dashboard, used in digest/alert email buttons (e.g. https://roz.acme.com).
DASHBOARD_URL=

# ── Anthropic (Claude — reasoning, classification, semantic dedup) ───────────────
ANTHROPIC_API_KEY=             # [required in prod]
ROZ_CLAUDE_MODEL=claude-haiku-4-5

# ── OpenAI (embeddings for the second brain) ────────────────────────────────────
OPENAI_API_KEY=
ROZ_EMBEDDING_MODEL=text-embedding-3-large
ROZ_EMBEDDING_DIM=3072

# ── Linear (roz is a layer on top of Linear + GitHub) ───────────────────────────
LINEAR_API_KEY=
LINEAR_WEBHOOK_SECRET=         # [required in prod] verifies Linear webhook signatures

# ── GitHub (read-only: commits, PRs, repos). See docs/GITHUB-SETUP.md ───────────
GITHUB_TOKEN=                  # fine-grained PAT: Contents read, Metadata read, Pull requests read
GITHUB_WEBHOOK_SECRET=         # [required in prod] HMAC secret shared with the GitHub webhook

# ── Email (Resend) ──────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=roz <onboarding@resend.dev>

# ── HyperOps fallback (optional, HyperLabs-internal) ────────────────────────────
# When false (default), roz resolves repo→project only via the direct roz.project_repo
# mapping + manual projects, and never reads a `public` schema. Leave false for self-host.
HYPEROPS_FALLBACK=false

# ── Infrastructure observability (all optional; degrade gracefully if unset) ─────
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=
RAILWAY_API_TOKEN=
SUPABASE_ACCESS_TOKEN=         # Supabase Management API personal access token

# ── Service tokens ──────────────────────────────────────────────────────────────
ROZ_MCP_TOKEN=                 # [required in prod] bearer for the MCP surface (Claude)
ROZ_INGEST_TOKEN=              # [required in prod] bearer for POST /v1/intake (client apps)
CRON_SECRET=                   # [required in prod] bearer Vercel Cron injects; without it crons 403

# ── Weekly digest ───────────────────────────────────────────────────────────────
# Comma-separated recipients of the team digest. Empty = team digest not sent.
DIGEST_RECIPIENTS=

# ── Web Push (PWA notifications) ─────────────────────────────────────────────────
# Push notifications to the installed PWA — fires for the same infra warnings as email.
# Optional: without VAPID keys, push degrades silently. Generate a pair once with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=              # exposed to the browser (safe to be public)
VAPID_PRIVATE_KEY=            # server-only secret — never expose to the client
VAPID_SUBJECT=mailto:roz@hyperdigital.mx   # contact (mailto: or https URL) required by the spec
