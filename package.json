{
  "name": "roz",
  "version": "0.1.0",
  "description": "roz — capa de contexto, enrutamiento y notificación alrededor del trabajo de desarrollo. Vercel serverless (Hono) + Supabase, ingesta vía Claude/MCP.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "mcp:stdio": "node dist/mcp/stdio.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "test:run": "vitest run",
    "vercel-build": "npm --prefix web install && npm --prefix web run build"
  },
  "keywords": [
    "roz",
    "mcp",
    "linear",
    "context",
    "routing"
  ],
  "license": "PROPRIETARY",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.5",
    "hono": "^4.6.0",
    "openai": "^4.67.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
