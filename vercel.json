{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    { "src": "web/package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } },
    { "src": "api/index.ts", "use": "@vercel/node", "config": { "maxDuration": 120 } }
  ],
  "routes": [
    { "src": "/webhooks/(.*)", "dest": "/api/index" },
    { "src": "/mcp/(.*)", "dest": "/api/index" },
    { "src": "/v1/(.*)", "dest": "/api/index" },
    { "src": "/api/(.*)", "dest": "/api/index" },
    { "src": "/health", "dest": "/api/index" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    { "path": "/v1/internal/drain", "schedule": "* * * * *" },
    { "path": "/v1/internal/brain-sweep", "schedule": "0 9 * * *" },
    { "path": "/v1/internal/weekly-digest", "schedule": "0 3 * * 6" }
  ]
}
