{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "web/dist",
  "functions": {
    "api/index.ts": { "maxDuration": 120 }
  },
  "rewrites": [
    { "source": "/webhooks/(.*)", "destination": "/api/index" },
    { "source": "/mcp/(.*)", "destination": "/api/index" },
    { "source": "/v1/(.*)", "destination": "/api/index" },
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/v1/internal/drain", "schedule": "* * * * *" },
    { "path": "/v1/internal/brain-sweep", "schedule": "0 9 * * *" },
    { "path": "/v1/internal/weekly-digest", "schedule": "0 3 * * 6" }
  ]
}
