{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm install --prefix web && npm run build --prefix web",
  "functions": {
    "api/index.ts": { "maxDuration": 120, "includeFiles": "web/dist/**" }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "crons": [
    { "path": "/v1/internal/drain", "schedule": "* * * * *" },
    { "path": "/v1/internal/infra-poll", "schedule": "*/15 * * * *" },
    { "path": "/v1/internal/brain-sweep", "schedule": "0 9 * * *" },
    { "path": "/v1/internal/weekly-digest", "schedule": "0 3 * * 6" }
  ]
}
