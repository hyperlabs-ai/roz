# roz dashboard (Vite) — environment configuration
# Copy to web/.env. Vite only reads this at startup, so restart the dev server after changes.

# Supabase project (same project as the backend). The anon key is safe to ship to the browser;
# it only validates the user's session — never expose the service_role key here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: comma-separated email domains allowed to sign in (client-side pre-check only).
# Leave empty to skip the pre-check — the backend still enforces DASHBOARD_ALLOWED_DOMAINS.
VITE_ALLOWED_EMAIL_DOMAINS=
